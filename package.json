{
  "name": "bal-vihar-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "prepare": "husky",
    "typegen": "turbo run typegen --filter=@bv/studio",
    "typegen:watch": "turbo run typegen:watch --filter=@bv/studio"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "turbo": "^2.5.8"
  }
}
